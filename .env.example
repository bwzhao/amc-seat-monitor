# AMC API Key (optional - falls back to scraping if not set)
AMC_API_KEY=

# Email notifications
NOTIFY_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# PushPlus (推送加) - get your token at https://www.pushplus.plus
PUSHPLUS_TOKEN=

# ServerChan (Server酱, legacy) - get your key at https://sct.ftqq.com
SERVERCHAN_KEY=

# Bark (iOS push) - get your key from the Bark app
BARK_KEY=
# Bark server URL (default: Apple's Bark service)
BARK_SERVER=https://api.day.app

# Server port
PORT=3000
